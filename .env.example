# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/earnings_calls
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Whisper
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_USE_LOCAL=true

# LLM
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Storage paths
AUDIO_STORAGE_PATH=./data/audio
TRANSCRIPT_STORAGE_PATH=./data/transcripts

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# API server
API_HOST=0.0.0.0
API_PORT=8000
